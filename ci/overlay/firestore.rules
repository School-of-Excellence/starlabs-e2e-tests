rules_version = '2';
// ⚠️ EMULATOR-ONLY permissive rules for local Tier-A testing. DO NOT wire this file into firebase.json
// (the deploy workflow runs a bare `firebase deploy`, which would push these open rules to production).
// Referenced only by firebase.emulator.json. Production rules live in the Firebase console / a separate, reviewed file.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
