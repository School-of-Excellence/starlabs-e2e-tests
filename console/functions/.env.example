# Copy to .env (gitignored) — NON-SECRET runtime config for the console functions.
# Secrets (GITHUB_WEBHOOK_SECRET, GITHUB_APP_PRIVATE_KEY) are NOT set here; they
# are stored in Secret Manager via `firebase functions:secrets:set` (see README).

# GitHub org that owns the four repos.
GITHUB_ORG=School-of-Excellence

# Numeric GitHub App id (App settings → "App ID").
GITHUB_APP_ID=TODO_APP_ID

# Installation id of the App on the org
# (Org → Settings → GitHub Apps → your app → Configure → the number in the URL,
#  or GET /orgs/{org}/installation).
GITHUB_APP_INSTALLATION_ID=TODO_INSTALLATION_ID
